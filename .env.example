# Flask Application Configuration Template
# Copy this file to .env and fill in your details

# Secret key for Flask sessions (generate a random string)
SECRET_KEY=b384e5964d98834d082dc208c8140f43

# Database URI (defaults to SQLite site.db in root if not specified)
# For production, e.g. PostgreSQL: postgresql://username:password@hostname:5432/databasename
DATABASE_URL=sqlite:///site.db

# Mail Server configuration (optional, for password resets)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Your email address (e.g. gmail address)
EMAIL_USER=your_email@gmail.com

# Your email password (e.g. Gmail App Password)
EMAIL_PASS=your_email_app_password
